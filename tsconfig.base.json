{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@kakai/shared": ["./packages/shared/src/index.ts"],
      "@kakai/shared/*": ["./packages/shared/src/*"],
      "@kakai/api": ["./packages/api/src/index.ts"],
      "@kakai/api/*": ["./packages/api/src/*"],
      "@kakai/i18n": ["./packages/i18n/src/index.ts"],
      "@kakai/i18n/*": ["./packages/i18n/src/*"]
    }
  }
}
