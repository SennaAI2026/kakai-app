        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8E6"
      },
      "package": "kz.kakai.child"
    },
    "extra": {
      "eas": {
        "projectId": "e8059c7e-5106-471e-823d-c5fda22e0601"
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-asset",
      "expo-font"
    ]
  }
}
