{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@kakai/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@kakai/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@kakai/api": [
        "../../packages/api/src/index.ts"
      ],
      "@kakai/api/*": [
        "../../packages/api/src/*"
      ],
      "@kakai/i18n": [
        "../../packages/i18n/src/index.ts"
      ],
      "@kakai/i18n/*": [
        "../../packages/i18n/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "../../packages/i18n/src/expo-localization.d.ts"
  ]
}
